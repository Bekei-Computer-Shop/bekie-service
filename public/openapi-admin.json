{
  "openapi": "3.0.3",
  "info": {
    "title": "Bekie Admin Panel API",
    "version": "1.0.0",
    "description": "Secure REST API for the Bekie admin panel with strong token-based authentication and role-based access control.",
    "contact": {
      "name": "Bekie Service",
      "email": "admin@bekie.com"
    },
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000/api/v1/admin",
      "description": "Local development server"
    },
    {
      "url": "https://api.bekie.com/v1/admin",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "Admin Authentication",
      "description": "Admin login, logout, and token management with strong authentication"
    },
    {
      "name": "Dashboard",
      "description": "Admin dashboard statistics and analytics"
    }
  ],
  "components": {
    "securitySchemes": {
      "AdminBearerToken": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Bearer Token",
        "description": "Admin access token with 120 minute expiration"
      }
    },
    "schemas": {
      "AdminAuthResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "Bearer token for API requests (120 min expiration)"
          },
          "refresh_token": {
            "type": "string",
            "description": "Token to refresh access token (30 day expiration)"
          },
          "token_type": {
            "type": "string",
            "enum": ["Bearer"]
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          },
          "user": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "email": { "type": "string" },
              "name": { "type": "string" },
              "roles": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "DashboardStats": {
        "type": "object",
        "properties": {
          "total_orders": { "type": "integer" },
          "total_revenue": { "type": "number" },
          "total_products": { "type": "integer" },
          "total_customers": { "type": "integer" },
          "today": { "type": "object" },
          "this_month": { "type": "object" },
          "this_year": { "type": "object" }
        }
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["success", "error"] },
          "message": { "type": "string" },
          "data": { "type": "object" }
        }
      }
    }
  },
  "security": [
    {"AdminBearerToken": []}
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "security": [],
        "tags": ["Admin Authentication"],
        "summary": "Admin login",
        "description": "Authenticate admin user with email and password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "format": "password" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Admin authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/AdminAuthResponse" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid admin credentials or admin access denied"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Admin Authentication"],
        "summary": "Admin logout",
        "responses": {
          "200": { "description": "Admin logout successful" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "security": [],
        "tags": ["Admin Authentication"],
        "summary": "Refresh admin access token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "refresh_token": { "type": "string" }
                },
                "required": ["refresh_token"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Token refreshed successfully" },
          "401": { "description": "Invalid or expired refresh token" }
        }
      }
    },
    "/dashboard": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Get admin dashboard statistics",
        "responses": {
          "200": {
            "description": "Dashboard statistics retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/DashboardStats" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden - admin role required" }
        }
      }
    }
  }
}

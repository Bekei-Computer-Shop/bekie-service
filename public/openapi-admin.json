{
  "openapi": "3.0.3",
  "info": {
    "title": "Bekie Admin Panel API",
    "version": "1.0.0",
    "description": "Secure REST API for the Bekie admin panel with strong token-based authentication and role-based access control.",
    "contact": {
      "name": "Bekie Service",
      "email": "admin@bekie.com"
    },
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000/api/v1/admin",
      "description": "Local development server"
    },
    {
      "url": "https://api.bekie.com/v1/admin",
      "description": "Production server"
    }
  ],
  "tags": [
    {
      "name": "Admin Authentication",
      "description": "Admin login, logout, and token management with strong authentication"
    },
    {
      "name": "Dashboard",
      "description": "Admin dashboard statistics and analytics"
    },
    {
      "name": "Product Management",
      "description": "Full CRUD operations for products, variants, and inventory management"
    },
    {
      "name": "Category Management",
      "description": "Manage product categories, including hierarchical structures and reordering"
    }
  ],
  "components": {
    "securitySchemes": {
      "AdminBearerToken": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Bearer Token",
        "description": "Admin access token with 120 minute expiration"
      }
    },
    "schemas": {
      "AdminAuthResponse": {
        "type": "object",
        "properties": {
          "access_token": {
            "type": "string",
            "description": "Bearer token for API requests (120 min expiration)"
          },
          "refresh_token": {
            "type": "string",
            "description": "Token to refresh access token (30 day expiration)"
          },
          "token_type": {
            "type": "string",
            "enum": ["Bearer"]
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          },
          "user": {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "email": { "type": "string" },
              "name": { "type": "string" },
              "roles": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      },
      "DashboardStats": {
        "type": "object",
        "properties": {
          "total_orders": { "type": "integer" },
          "total_revenue": { "type": "number" },
          "total_products": { "type": "integer" },
          "total_customers": { "type": "integer" },
          "today": { "type": "object" },
          "this_month": { "type": "object" },
          "this_year": { "type": "object" }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 101 },
          "name": { "type": "string", "example": "Premium Wireless Headphones" },
          "slug": { "type": "string", "example": "premium-wireless-headphones" },
          "description": { "type": "string", "nullable": true, "example": "High-fidelity audio with noise cancellation." },
          "status": { "type": "string", "enum": ["draft", "published", "out_of_stock"], "example": "published" },
          "base_price": { "type": "number", "example": 299.99 },
          "brand": { "type": "object", "properties": { "id": { "type": "integer" }, "name": { "type": "string" } } },
          "categories": { "type": "array", "items": { "type": "object" } },
          "tags": { "type": "array", "items": { "type": "string" }, "example": ["electronics", "audio"] },
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "integer" },
                "sku": { "type": "string", "example": "HD-WRLS-BLK" },
                "name": { "type": "string", "example": "Midnight Black" },
                "price": { "type": "number", "example": 299.99 },
                "stock": { "type": "integer", "example": 50 }
              }
            }
          },
          "images": { "type": "array", "items": { "type": "object", "properties": { "path": { "type": "string" } } } },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "StoreProductRequest": {
        "type": "object",
        "required": ["name", "slug", "brand_id", "category_ids", "status", "base_price", "variants"],
        "properties": {
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "description": { "type": "string" },
          "brand_id": { "type": "integer" },
          "category_ids": { "type": "array", "items": { "type": "integer" } },
          "status": { "type": "string", "enum": ["draft", "published", "out_of_stock"] },
          "base_price": { "type": "number" },
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["sku", "name", "price", "stock"],
              "properties": {
                "sku": { "type": "string" },
                "name": { "type": "string" },
                "price": { "type": "number" },
                "stock": { "type": "integer" },
                "attributes": { "type": "object" }
              }
            }
          },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      },
      "BulkStatusRequest": {
        "type": "object",
        "required": ["product_ids", "status"],
        "properties": {
          "product_ids": {
            "type": "array",
            "items": { "type": "integer" },
            "example": [101, 102, 105]
          },
          "status": { "type": "string", "enum": ["draft", "published", "out_of_stock"] }
        }
      },
      "BulkDeleteRequest": {
        "type": "object",
        "required": ["product_ids"],
        "properties": {
          "product_ids": {
            "type": "array",
            "items": { "type": "integer" },
            "example": [101, 102]
          }
        }
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["success", "error"] },
          "message": { "type": "string" },
          "data": { "type": "object" }
        }
      }
      ,
      "Category": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "parent_id": { "type": "integer", "nullable": true, "example": null },
          "name": { "type": "string", "example": "Electronics" },
          "slug": { "type": "string", "example": "electronics" },
          "description": { "type": "string", "nullable": true, "example": "Electronic gadgets and devices." },
          "order": { "type": "integer", "example": 1 },
          "is_active": { "type": "boolean", "example": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "children": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Category" }
          }
        }
      },
      "CategoryRequest": {
        "type": "object",
        "required": ["name", "slug"],
        "properties": {
          "name": { "type": "string", "example": "New Category" },
          "slug": { "type": "string", "example": "new-category" },
          "description": { "type": "string", "nullable": true, "example": "Description for the new category." },
          "parent_id": { "type": "integer", "nullable": true, "example": 1 },
          "order": { "type": "integer", "example": 1 },
          "is_active": { "type": "boolean", "example": true }
        }
      },
      "CategoryReorderRequest": {
        "type": "object",
        "required": ["categories"],
        "properties": {
          "categories": {
            "type": "array",
            "description": "Array of category objects with their new order and optional parent_id.",
            "items": {
              "type": "object",
              "required": ["id", "order"],
              "properties": {
                "id": { "type": "integer", "example": 1 },
                "order": { "type": "integer", "example": 1 },
                "parent_id": { "type": "integer", "nullable": true, "example": null }
              }
            }
          }
        }
      },
      "CategoryBulkDeleteRequest": {
        "type": "object",
        "required": ["category_ids"],
        "properties": {
          "category_ids": {
            "type": "array",
            "items": { "type": "integer" },
            "example": [1, 2, 3]
          }
        }
      }
    }
  },
  "security": [
    {"AdminBearerToken": []}
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "security": [],
        "tags": ["Admin Authentication"],
        "summary": "Admin login",
        "description": "Authenticate admin user with email and password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "format": "password" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Admin authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/AdminAuthResponse" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid admin credentials or admin access denied"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Admin Authentication"],
        "summary": "Admin logout",
        "responses": {
          "200": { "description": "Admin logout successful" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "security": [],
        "tags": ["Admin Authentication"],
        "summary": "Refresh admin access token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "refresh_token": { "type": "string" }
                },
                "required": ["refresh_token"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Token refreshed successfully" },
          "401": { "description": "Invalid or expired refresh token" }
        }
      }
    },
    "/dashboard": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Get admin dashboard statistics",
        "responses": {
          "200": {
            "description": "Dashboard statistics retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/DashboardStats" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden - admin role required" }
        }
      }
    },
    "/products": {
      "get": {
        "tags": ["Product Management"],
        "summary": "List products with filtering",
        "parameters": [
          { "name": "category_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "brand_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "default": 15 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Product" } },
                    "meta": { "type": "object" },
                    "links": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Product Management"],
        "summary": "Create a new product",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/StoreProductRequest" } }
          }
        },
        "responses": {
          "201": {
            "description": "Product created successfully",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Product" } }
            }
          }
        }
      }
    },
    "/products/{id}": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
      ],
      "get": {
        "tags": ["Product Management"],
        "summary": "Get product details",
        "responses": {
          "200": {
            "description": "Product detailed info",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Product" } }
            }
          },
          "404": { "description": "Product not found" }
        }
      },
      "put": {
        "tags": ["Product Management"],
        "summary": "Update an existing product",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/StoreProductRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "Product updated successfully",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Product" } }
            }
          }
        }
      },
      "delete": {
        "tags": ["Product Management"],
        "summary": "Delete a product",
        "responses": {
          "204": { "description": "Product deleted successfully" }
        }
      }
    },
    "/products/{id}/status": {
      "patch": {
        "tags": ["Product Management"],
        "summary": "Update individual product status",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string", "enum": ["draft", "published", "out_of_stock"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Status updated successfully" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/products/bulk-status": {
      "post": {
        "tags": ["Product Management"],
        "summary": "Bulk update product statuses",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/BulkStatusRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk status update initiated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Bulk status update completed for 3 products" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/products/bulk-delete": {
      "post": {
        "tags": ["Product Management"],
        "summary": "Bulk delete products",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/BulkDeleteRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk deletion successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Bulk delete completed successfully" }
                  }
                }
              }
            }
          }
        }
      }
    }
    ,
    "/categories": {
      "get": {
        "tags": ["Category Management"],
        "summary": "List categories",
        "description": "Retrieve a paginated list of categories. Can filter by parent_id to get direct children.",
        "parameters": [
          { "name": "parent_id", "in": "query", "schema": { "type": "integer", "nullable": true }, "description": "Filter by parent category ID. If null, returns root categories." },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "default": 15 } },
          { "name": "search", "in": "query", "schema": { "type": "string" }, "description": "Search categories by name or slug." }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of categories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Category" } },
                    "meta": { "type": "object" },
                    "links": { "type": "object" }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      },
      "post": {
        "tags": ["Category Management"],
        "summary": "Create a new category",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CategoryRequest" } }
          }
        },
        "responses": {
          "201": {
            "description": "Category created successfully",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Category" } }
            }
          },
          "422": { "description": "Validation error" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/categories/tree": {
      "get": {
        "tags": ["Category Management"],
        "summary": "Get full category tree",
        "description": "Retrieve all categories in a nested, hierarchical structure.",
        "responses": {
          "200": {
            "description": "Category tree retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Category" } }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/categories/{id}": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "ID of the category" }
      ],
      "get": {
        "tags": ["Category Management"],
        "summary": "Get category details",
        "responses": {
          "200": {
            "description": "Category detailed info",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Category" } }
            }
          },
          "404": { "description": "Category not found" },
          "401": { "description": "Unauthorized" }
        }
      },
      "put": {
        "tags": ["Category Management"],
        "summary": "Update an existing category",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CategoryRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "Category updated successfully",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Category" } }
            }
          },
          "404": { "description": "Category not found" },
          "422": { "description": "Validation error" },
          "401": { "description": "Unauthorized" }
        }
      },
      "delete": {
        "tags": ["Category Management"],
        "summary": "Delete a category",
        "responses": {
          "204": { "description": "Category deleted successfully" },
          "404": { "description": "Category not found" },
          "409": { "description": "Conflict: Cannot delete category with children or linked products" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/categories/reorder": {
      "post": {
        "tags": ["Category Management"],
        "summary": "Reorder categories",
        "description": "Update the order and parent_id for multiple categories.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CategoryReorderRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "Categories reordered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Categories reordered successfully." }
                  }
                }
              }
            }
          },
          "422": { "description": "Validation error" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/categories/bulk-delete": {
      "post": {
        "tags": ["Category Management"],
        "summary": "Bulk delete categories",
        "description": "Soft delete multiple categories by their IDs.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/CategoryBulkDeleteRequest" } }
          }
        },
        "responses": {
          "200":
          {
            "description": "Bulk deletion successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Bulk delete completed successfully for 3 categories." }
                  }
                }
              }
            }
          },
          "409": { "description": "Conflict: One or more categories cannot be deleted due to children or linked products." },
          "422": { "description": "Validation error" },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  }
}

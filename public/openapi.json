{
  "openapi": "3.0.3",
  "info": {
    "title": "Bekie E-commerce API",
    "version": "1.0.0",
    "description": "REST API for the Bekie e-commerce platform. All endpoints are versioned under /api/v1/.",
    "contact": {
      "name": "Bekie Service"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000/api/v1",
      "description": "Local development server"
    }
  ],
  "tags": [
    { "name": "Categories", "description": "Category browsing and details" },
    { "name": "Brands", "description": "Brand browsing and details" },
    { "name": "Products", "description": "Product browsing and variants" },
    { "name": "Shipping", "description": "Shipping methods and checkout options" },
    { "name": "Coupons", "description": "Coupon validation and application" },
    { "name": "Carts", "description": "Cart management and checkout" },
    { "name": "Wishlists", "description": "Wishlist lifecycle and item management" },
    { "name": "Orders", "description": "Order creation and retrieval" },
    { "name": "Authentication", "description": "Login, logout, and token refresh" }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Bearer"
      }
    }
  },
  "security": [
    { "BearerAuth": [] }
  ],
  "paths": {
    "/categories": {
      "get": {
        "security": [],
        "tags": ["Categories"],
        "summary": "List categories",
        "responses": {
          "200": {
            "description": "A paginated list of categories"
          }
        }
      }
    },
    "/categories/{category}": {
      "get": {
        "security": [],
        "tags": ["Categories"],
        "summary": "Retrieve a category",
        "parameters": [
          { "name": "category", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Category details" } }
      }
    },
    "/brands": {
      "get": {
        "security": [],
        "tags": ["Brands"],
        "summary": "List brands",
        "responses": { "200": { "description": "A paginated list of brands" } }
      }
    },
    "/brands/{brand}": {
      "get": {
        "security": [],
        "tags": ["Brands"],
        "summary": "Retrieve brand details",
        "parameters": [
          { "name": "brand", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Brand details" } }
      }
    },
    "/products": {
      "get": {
        "security": [],
        "tags": ["Products"],
        "summary": "List products",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "category_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "brand_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "A paginated product collection" } }
      }
    },
    "/products/{product}": {
      "get": {
        "security": [],
        "tags": ["Products"],
        "summary": "Retrieve product details",
        "parameters": [
          { "name": "product", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Product details" } }
      }
    },
    "/products/{product}/variants": {
      "get": {
        "security": [],
        "tags": ["Products"],
        "summary": "List product variants",
        "parameters": [
          { "name": "product", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Product variants" } }
      }
    },
    "/shipping-methods": {
      "get": {
        "security": [],
        "tags": ["Shipping"],
        "summary": "List active shipping methods",
        "responses": { "200": { "description": "A shipping method collection" } }
      }
    },
    "/auth/login": {
      "post": {
        "security": [],
        "tags": ["Authentication"],
        "summary": "Log in and receive an access token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful"
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "security": [],
        "tags": ["Authentication"],
        "summary": "Refresh an expired access token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "refresh_token": { "type": "string" }
                },
                "required": ["refresh_token"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token refreshed successfully"
          },
          "401": {
            "description": "Refresh token invalid or expired"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Revoke the current access token",
        "responses": {
          "200": {
            "description": "Logged out successfully"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/coupons/apply": {
      "post": {
        "tags": ["Coupons"],
        "summary": "Apply a coupon code to a cart",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cart_id": { "type": "integer" },
                  "code": { "type": "string" }
                },
                "required": ["cart_id", "code"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Coupon applied" } }
      }
    },
    "/carts": {
      "get": { "tags": ["Carts"], "summary": "List carts", "responses": { "200": { "description": "Cart collection" } } },
      "post": {
        "tags": ["Carts"],
        "summary": "Create a new cart",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "session_id": { "type": "string" },
                  "currency": { "type": "string", "default": "USD" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Cart created" } }
      }
    },
    "/carts/{cart}": {
      "get": {
        "tags": ["Carts"],
        "summary": "Get cart details",
        "parameters": [{ "name": "cart", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Cart details" } }
      }
    },
    "/carts/{cart}/items": {
      "post": {
        "tags": ["Carts"],
        "summary": "Add an item to a cart",
        "parameters": [{ "name": "cart", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "product_id": { "type": "integer" },
                  "product_variant_id": { "type": "integer" },
                  "quantity": { "type": "integer", "default": 1 }
                },
                "required": ["product_id", "quantity"]
              }
            }
          }
        },
        "responses": { "201": { "description": "Cart item added" } }
      }
    },
    "/carts/{cart}/items/{item}": {
      "patch": {
        "tags": ["Carts"],
        "summary": "Update a cart item",
        "parameters": [
          { "name": "cart", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "item", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "quantity": { "type": "integer" } } } } }
        },
        "responses": { "200": { "description": "Cart item updated" } }
      },
      "delete": {
        "tags": ["Carts"],
        "summary": "Remove a cart item",
        "parameters": [
          { "name": "cart", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "item", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "204": { "description": "Item removed" } }
      }
    },
    "/carts/{cart}/checkout": {
      "post": {
        "tags": ["Carts"],
        "summary": "Checkout a cart and place an order",
        "parameters": [{ "name": "cart", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "shipping_method_id": { "type": "integer" },
                  "address_id": { "type": "integer" },
                  "recipient_name": { "type": "string" },
                  "phone": { "type": "string" },
                  "address_line_1": { "type": "string" },
                  "city": { "type": "string" },
                  "country": { "type": "string" }
                },
                "required": ["shipping_method_id", "recipient_name", "address_line_1", "city", "country"]
              }
            }
          }
        },
        "responses": { "201": { "description": "Order created" } }
      }
    },
    "/wishlists": {
      "get": { "tags": ["Wishlists"], "summary": "List wishlists", "responses": { "200": { "description": "Wishlist collection" } } },
      "post": {
        "tags": ["Wishlists"],
        "summary": "Create a wishlist",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "name": { "type": "string" }, "session_id": { "type": "string" } }, "required": ["name"] } } }
        },
        "responses": { "201": { "description": "Wishlist created" } }
      }
    },
    "/wishlists/{wishlist}": {
      "get": {
        "tags": ["Wishlists"],
        "summary": "Get a wishlist",
        "parameters": [{ "name": "wishlist", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Wishlist details" } }
      },
      "delete": {
        "tags": ["Wishlists"],
        "summary": "Delete a wishlist",
        "parameters": [{ "name": "wishlist", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "204": { "description": "Wishlist deleted" } }
      }
    },
    "/wishlists/{wishlist}/items": {
      "post": {
        "tags": ["Wishlists"],
        "summary": "Add an item to a wishlist",
        "parameters": [{ "name": "wishlist", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "product_id": { "type": "integer" }, "product_variant_id": { "type": "integer" } }, "required": ["product_id"] } } }
        },
        "responses": { "201": { "description": "Wishlist item added" } }
      }
    },
    "/wishlists/{wishlist}/items/{item}": {
      "delete": {
        "tags": ["Wishlists"],
        "summary": "Remove an item from a wishlist",
        "parameters": [
          { "name": "wishlist", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "item", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "204": { "description": "Item removed from wishlist" } }
      }
    },
    "/orders": {
      "get": { "tags": ["Orders"], "summary": "List orders", "responses": { "200": { "description": "Order list" } } },
      "post": {
        "tags": ["Orders"],
        "summary": "Create an order",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "cart_id": { "type": "integer" }, "shipping_method_id": { "type": "integer" }, "address_id": { "type": "integer" }, "recipient_name": { "type": "string" }, "phone": { "type": "string" }, "address_line_1": { "type": "string" }, "city": { "type": "string" }, "country": { "type": "string" } }, "required": ["cart_id", "shipping_method_id", "recipient_name", "address_line_1", "city", "country"] } } }
        },
        "responses": { "201": { "description": "Order created" } }
      }
    },
    "/orders/{order}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get an order",
        "parameters": [{ "name": "order", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Order details" } }
      }
    }
  }
}
